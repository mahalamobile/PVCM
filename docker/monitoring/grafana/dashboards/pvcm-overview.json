{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "stat",
      "title": "Service Up",
      "id": 1,
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "up{job=\"pvcm_metrics\"}",
          "legendFormat": "up"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } }
          ],
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "textMode": "value",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "type": "stat",
      "title": "Total Campaigns",
      "id": 2,
      "gridPos": { "x": 4, "y": 0, "w": 5, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "pvcm_campaigns_total" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      },
      "options": {
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "type": "stat",
      "title": "Active Campaigns",
      "id": 3,
      "gridPos": { "x": 9, "y": 0, "w": 5, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "pvcm_campaigns_active" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "green" }
        }
      },
      "options": {
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "type": "stat",
      "title": "Videos Ingested",
      "id": 4,
      "gridPos": { "x": 14, "y": 0, "w": 5, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "pvcm_campaign_data_total" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "purple" }
        }
      },
      "options": {
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "type": "stat",
      "title": "Duplicate Payloads",
      "id": 5,
      "gridPos": { "x": 19, "y": 0, "w": 5, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "pvcm_campaign_duplicates_total" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "orange" }
        }
      },
      "options": {
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "type": "timeseries",
      "title": "Queue Depth",
      "id": 6,
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "pvcm_jobs_pending", "legendFormat": "all queues" },
        { "refId": "B", "expr": "pvcm_jobs_campaign_data_pending", "legendFormat": "campaign-data" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never",
            "spanNulls": true
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "type": "timeseries",
      "title": "Ingestion Rate (videos/min)",
      "id": 7,
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(pvcm_campaign_data_total[5m]) * 60",
          "legendFormat": "ingested /min"
        },
        {
          "refId": "B",
          "expr": "rate(pvcm_campaign_duplicates_total[5m]) * 60",
          "legendFormat": "duplicates /min"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "type": "timeseries",
      "title": "Campaigns Over Time",
      "id": 8,
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 7 },
      "targets": [
        { "refId": "A", "expr": "pvcm_campaigns_total", "legendFormat": "total" },
        { "refId": "B", "expr": "pvcm_campaigns_active", "legendFormat": "active" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "type": "bargauge",
      "title": "Videos Per Campaign",
      "id": 9,
      "gridPos": { "x": 0, "y": 19, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sort_desc(pvcm_campaign_data_by_campaign)",
          "legendFormat": "{{campaign_name}} (#{{campaign_id}})",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "continuous-BlPu" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "valueMode": "color",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Videos Per Campaign (over time)",
      "id": 10,
      "gridPos": { "x": 12, "y": 19, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "pvcm_campaign_data_by_campaign",
          "legendFormat": "{{campaign_name}} (#{{campaign_id}})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 12,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "mode": "none", "group": "A" }
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    }
  ],
  "refresh": "15s",
  "schemaVersion": 39,
  "tags": ["pvcm", "laravel"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "PVCM Overview",
  "uid": "pvcm-overview",
  "version": 2,
  "weekStart": ""
}
